# Copy to .env and edit. Real env vars override values here.

# Server-side snapshot cache (seconds).
CACHE_TTL=30

# curl timeout per IPP request (seconds).
POLL_TIMEOUT=10

# IPP endpoint (most printers use these — some HP models need /ipp/printer).
IPP_PORT=631
IPP_PATH=/ipp/print

# Printers: add PRINTER_<N>_NAME / PRINTER_<N>_IP pairs. Gaps are fine.
PRINTER_1_NAME=Lab Color
PRINTER_1_IP=10.0.0.50

PRINTER_2_NAME=Front desk
PRINTER_2_IP=printer.lan
